{
  "version": 2,
  "cleanUrls": true,
  "builds": [
    { "src": "*.html",   "use": "@vercel/static" },
    { "src": "style.css","use": "@vercel/static" },
    { "src": "api/*.js", "use": "@vercel/node"   }
  ],
  "routes": [
    { "src": "/api/(.*)",    "dest": "/api/$1"           },
    { "src": "/menu/(.*)",  "dest": "/menu.html"        },
    { "src": "/dashboard",  "dest": "/dashboard.html"   },
    { "src": "/restaurant", "dest": "/restaurant.html"  },
    { "src": "/order",      "dest": "/order.html"       },
    { "src": "/",           "dest": "/index.html"       }
  ]
}
